# Server
PORT=3333

# Database (matches docker-compose defaults)
POSTGRES_USER=biker
POSTGRES_PASSWORD=biker
POSTGRES_DB=biker_app
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://biker:biker@localhost:5432/biker_app

# Auth
BETTER_AUTH_SECRET=change-me-to-a-random-32-char-string

# Social providers (optional — remove if not using)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
